# Claude Code
.claude/*.local.*
.claude/worktrees/

# Dependencies
node_modules/

# Build outputs
build/
/.svelte-kit

# Rust / Cargo
target/
# PH-CF-1210 ⑨: ローカルで `cargo build --features test-launch-seam` した時に
# user dev binary とぶつからないよう CARGO_TARGET_DIR を target-e2e/ に逃すための buffer。
target-e2e/
**/*.rs.bk

# SQLite
*.db
*.db-journal
*.db-wal
*.db-shm

# Environment / secrets
.env
.env.*
!.env.example
!.env.test

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Editor / IDE
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Logs
*.log

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Temporary artifacts (screenshots, etc.)
tmp/

# Playwright test artifacts (locally generated)
test-results/
test-results-en/
.claude/scheduled_tasks.lock
dist/

# Personal data (user 実機由来の fixture / dump、 commit 禁止)
# - tmp/ 全体は上で ignored 済 (verify-shots / theme-shots / seed-and-shoot.mjs もここで覆う)
# - *.db も上で ignored 済 (実 DB 紛れ防止)
tests/fixtures/personal-*
tests/fixtures/local-*
**/agent-verify/
**/*.personal.*

# audit-personal-data の user 個別 pattern (brand / 実 item 名 等の自分専用辞書)
scripts/.personal-data-patterns.local.txt
