{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Arcagate",
  "version": "0.1.1",
  "identifier": "com.arcagate.desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Arcagate",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": false,
        "shadow": true,
        "transparent": true,
        "windowEffects": {
          "effects": ["mica"]
        }
      },
      {
        "label": "palette",
        "title": "Arcagate Palette",
        "url": "/palette",
        "width": 900,
        "height": 620,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "resizable": false,
        "center": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
      "freezePrototype": true,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/icons/**",
          "$APPDATA/wallpapers/**",
          "$APPDATA/image-scraps/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/emanon-i/arcagate/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZENDExNEMzMkU1N0VGRTIKUldUaTcxY3V3eFJCL2VSWmwxWW5PbUllakVZbW5KeUdoajdOUytRSEgxbFhuejV6a2RzZU1LVHUK"
    }
  }
}
