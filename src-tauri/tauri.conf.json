{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Arcagate",
  "version": "0.1.0",
  "identifier": "com.arcagate.desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Arcagate",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": false,
        "shadow": true
      },
      {
        "label": "palette",
        "title": "Arcagate Palette",
        "url": "/palette",
        "width": 900,
        "height": 620,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "resizable": false,
        "center": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/icons/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/emanon-i/arcagate/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "PLACEHOLDER_REGENERATE_WITH_TAURI_SIGNER"
    }
  }
}
