{
	"name": "arcagate",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"packageManager": "pnpm@10.30.3",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:smoke": "playwright test --grep @smoke",
		"test:e2e:core": "playwright test --grep @core",
		"tauri": "tauri",
		"verify:smoke": "bash scripts/smoke-test.sh",
		"audit:hotkey": "bash scripts/audit-hotkey-consistency.sh",
		"audit:design-tokens": "bash scripts/audit-design-tokens.sh",
		"audit:text-overflow": "bash scripts/audit-text-overflow.sh",
		"audit:all": "bash scripts/audit-widget-coverage.sh && bash scripts/audit-hotkey-consistency.sh && bash scripts/audit-design-tokens.sh && bash scripts/audit-text-overflow.sh",
		"verify": "pnpm biome check && pnpm dprint check && pnpm audit:all && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings && cargo fmt --manifest-path src-tauri/Cargo.toml --check && pnpm check && cargo test --manifest-path src-tauri/Cargo.toml && pnpm verify:smoke && pnpm test && pnpm tauri build"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"dprint",
			"esbuild",
			"lefthook"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@internationalized/date": "3.10.0",
		"@lucide/svelte": "^0.561.0",
		"@playwright/test": "^1.52.0",
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/cli": "^2.10.0",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.2",
		"@tauri-apps/plugin-dialog": "^2.6.0",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.3.3",
		"@vitest/coverage-v8": "^4.1.5",
		"bits-ui": "2.14.4",
		"clsx": "2.1.1",
		"dprint": "^0.52.0",
		"jsdom": "^28.1.0",
		"lefthook": "^2.1.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"tailwind-merge": "3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@tauri-apps/plugin-fs": "^2.4.5",
		"@tauri-apps/plugin-updater": "^2.10.1"
	}
}
