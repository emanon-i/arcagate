{
	"name": "arcagate",
	"private": true,
	"version": "0.1.1",
	"type": "module",
	"packageManager": "pnpm@10.30.3",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:en": "playwright test --config playwright.en.config.ts",
		"test:perf": "playwright test --config playwright.perf.config.ts",
		"tauri": "tauri",
		"app:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
		"verify:smoke": "bash scripts/smoke-test.sh",
		"audit:hotkey": "bash scripts/audit-hotkey-consistency.sh",
		"audit:design-tokens": "bash scripts/audit-design-tokens.sh",
		"audit:async-commands": "bash scripts/audit-async-commands.sh",
		"audit:blocking-on-runtime": "bash scripts/audit-blocking-on-runtime.sh",
		"audit:personal-data": "bash scripts/audit-personal-data.sh",
		"audit:stub-action": "bash scripts/audit-stub-action.sh",
		"audit:source-back-link": "bash scripts/audit-source-back-link.sh",
		"audit:window-confirm": "bash scripts/audit-window-confirm.sh",
		"audit:sticky-bar": "bash scripts/audit-sticky-bar-occlusion.sh",
		"audit:widget-default-config": "bash scripts/audit-widget-default-config.sh",
		"audit:library-sidebar-icons": "bash scripts/audit-library-sidebar-icons.sh",
		"audit:no-hud-references": "bash scripts/audit-no-hud-references.sh",
		"audit:overlay-drag-region": "bash scripts/audit-overlay-drag-region.sh",
		"audit:no-test-hook-leak": "bash scripts/audit-no-test-hook-leak.sh",
		"audit:item-cascade-helper": "bash scripts/audit-item-cascade-helper.sh",
		"audit:widget-default-size-budget": "bash scripts/audit-widget-default-size-budget.sh",
		"audit:appearance-state-mgmt": "bash scripts/audit-appearance-state-mgmt.sh",
		"audit:widget-context-opener": "bash scripts/audit-widget-context-opener.sh",
		"audit:launcher-spawn-leak": "bash scripts/audit-launcher-spawn-leak.sh",
		"audit:builtin-theme-css-vars": "bash scripts/audit-builtin-theme-css-vars.sh",
		"audit:readme-data-location": "bash scripts/audit-readme-data-location.sh",
		"audit:all": "bash scripts/audit-widget-coverage.sh && bash scripts/audit-hotkey-consistency.sh && bash scripts/audit-design-tokens.sh && bash scripts/audit-async-commands.sh && bash scripts/audit-blocking-on-runtime.sh && bash scripts/audit-personal-data.sh && bash scripts/audit-stub-action.sh && bash scripts/audit-source-back-link.sh && bash scripts/audit-window-confirm.sh && bash scripts/audit-sticky-bar-occlusion.sh && bash scripts/audit-widget-default-config.sh && bash scripts/audit-library-sidebar-icons.sh && bash scripts/audit-no-hud-references.sh && bash scripts/audit-overlay-drag-region.sh && bash scripts/audit-no-test-hook-leak.sh && bash scripts/audit-item-cascade-helper.sh && bash scripts/audit-widget-default-size-budget.sh && bash scripts/audit-appearance-state-mgmt.sh && bash scripts/audit-widget-context-opener.sh && bash scripts/audit-launcher-spawn-leak.sh && bash scripts/audit-builtin-theme-css-vars.sh && bash scripts/audit-readme-data-location.sh",
		"verify": "pnpm biome check && pnpm dprint check && pnpm audit:all && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings && cargo fmt --manifest-path src-tauri/Cargo.toml --check && pnpm check && cargo test --manifest-path src-tauri/Cargo.toml && pnpm verify:smoke && pnpm test && pnpm tauri build"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"dprint",
			"esbuild",
			"lefthook"
		]
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@biomejs/biome": "^2.4.4",
		"@internationalized/date": "3.10.0",
		"@lucide/svelte": "^0.561.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/cli": "^2.11.0",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.2",
		"@tauri-apps/plugin-dialog": "^2.6.0",
		"@types/node": "^25.3.3",
		"bits-ui": "2.14.4",
		"clsx": "2.1.1",
		"dprint": "^0.52.0",
		"lefthook": "^2.1.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"tailwind-merge": "3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@tauri-apps/plugin-fs": "^2.4.5",
		"@tauri-apps/plugin-updater": "^2.10.1"
	}
}
